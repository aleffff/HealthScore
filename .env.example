MARIADB_DATABASE=healthscore
MARIADB_USER=healthscore
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-root-me

# OAuth 2.0 client_credentials. Nunca versionar valores reais.
SALESFORCE_LOGIN_URL=https://suportelinx.my.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_API_VERSION=v63.0

SYNC_INTERVAL_MINUTES=60
SYNC_INITIAL_LOOKBACK_DAYS=730
SYNC_WATERMARK_OVERLAP_MINUTES=5

# local para desenvolvimento; oidc em produção.
AUTH_MODE=local
AUTH_AUTHORITY=
AUTH_AUDIENCE=
AUTH_CLIENT_ID=
AUTH_SCOPE=openid profile email healthscore-api
AUTH_ROLES_CLAIM=roles
AUTH_GROUPS_CLAIM=groups
AUTH_GROUP_VIEWER=
AUTH_GROUP_OPERATOR=
AUTH_GROUP_SCORE_ADMIN=
AUTH_GROUP_SYSTEM_ADMIN=
ASPNETCORE_ENVIRONMENT=Development
